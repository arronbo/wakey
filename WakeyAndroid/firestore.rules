// Wakey Firestore 安全規則
// 部署：Firebase Console → Firestore Database → Rules → 貼上 → Publish
// （程式完成、實測登入與同步都正常後再切換到此嚴格規則）

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // profile 可被任何已登入者讀取（好友配對需要讀對方資料）
      allow read: if request.auth != null;
      // 只有本人能寫自己的 profile / settings
      allow write: if request.auth != null && request.auth.uid == userId;

      // 好友子集合：本人可讀寫；另允許「對方寫入自己這一側」以支援雙向加好友
      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null &&
                     (request.auth.uid == userId || request.auth.uid == friendId);
      }

      // 鬧鐘子集合：只有本人可讀寫
      match /alarms/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 共享群組（全域 collection；邀請制）
    //   memberUids: List<String>   // 已加入成員 uid（含 owner）
    //   pendingUids: List<String>  // 被邀請尚未同意的 uid
    //   ownerUid: String           // 建立者
    //
    // 規則：
    //   read：成員或被邀請者都可讀（後者要看到邀請）
    //   create：自己當 owner、自己在 memberUids
    //   delete：只有 owner
    //   update：owner 可改全部；其他人只能改 memberUids/pendingUids 兩個欄位
    //          （拿來：接受邀請、拒絕邀請、退出群組、掃 QR 加入）
    match /groups/{groupId} {
      allow read: if request.auth != null
                  && (request.auth.uid in resource.data.memberUids
                      || request.auth.uid in resource.data.pendingUids);
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.auth.uid in request.resource.data.memberUids;
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
                    && (
                      resource.data.ownerUid == request.auth.uid
                      || (
                        // 非 owner：核心欄位不變，只動 memberUids/pendingUids
                        request.resource.data.ownerUid == resource.data.ownerUid
                        && request.resource.data.name == resource.data.name
                        && request.resource.data.message == resource.data.message
                        && request.resource.data.color == resource.data.color
                      )
                    );
    }

    // 喚醒語音訊息（一次性，收件人讀取後刪除）
    match /wake_messages/{messageId} {
      // 寄件人 create：自己當 senderUid
      allow create: if request.auth != null
                    && request.resource.data.senderUid == request.auth.uid;
      // 收件人 read：目標就是自己
      allow read: if request.auth != null
                  && resource.data.targetUid == request.auth.uid;
      // 雙方都能 delete（收件人播完刪、寄件人需要時也可清除）
      allow delete: if request.auth != null
                    && (resource.data.senderUid == request.auth.uid
                        || resource.data.targetUid == request.auth.uid);
    }
  }
}
